<% const vs = typeof vaultShop !== 'undefined' ? vaultShop : {}; %>
<% const p = vs.prices || { reroll: 0, shield: 0, focusSip: 0 }; %>
<% const vf = typeof vaultFlash !== 'undefined' ? vaultFlash : null; %>
<% const curName = typeof softCurrencyName === 'string' ? softCurrencyName : 'Astra'; %>
<% const va = Array.isArray(vaultActivity) ? vaultActivity : []; %>

<div class="mb-4">
  <h1 class="font-display text-2xl font-bold uppercase tracking-wide text-zinc-50 sm:text-3xl md:text-4xl">Vault</h1>
  <p class="mt-1 font-ui text-[13px] text-zinc-400 sm:text-sm">Inventory, cosmetics, and the Astra exchange.</p>
</div>

<% if (vf) { %>
<div
  class="mb-4 rounded-xl border px-3 py-2 font-ui text-sm <%= vf.type === 'ok' ? 'border-emerald-600/50 bg-emerald-950/40 text-emerald-100' : 'border-rose-600/50 bg-rose-950/35 text-rose-100' %>"
  role="status"
>
  <%= vf.text %>
</div>
<% } %>

<section class="mb-4 grid grid-cols-2 gap-4">
  <div class="rounded-2xl border border-zinc-700/80 bg-gradient-to-br from-zinc-900 to-zinc-800/90 p-4 shadow-lg md:rounded-3xl md:p-5">
    <h2 class="mb-3 font-display text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-300">Your vault</h2>
    <div id="vault-grid" class="grid grid-cols-4 gap-2">
      <button type="button" data-vault-item="shield" data-vault-action="use_streak_shield" data-can-use="<%= vs.canUseShield ? 1 : 0 %>" data-name="Streak Shield" data-desc="Use to arm 1 shield protection. It only triggers after one missed day." class="group relative flex aspect-square cursor-pointer items-center justify-center rounded-lg border border-zinc-700 bg-zinc-950/70 p-2 overflow-visible">
        <img src="/images/ui/item-shield.svg" alt="Streak Shield" class="h-5 w-5" />
        <span class="absolute bottom-1 right-1 rounded bg-zinc-700/95 px-1.5 py-0.5 font-mono text-[9px] leading-none text-zinc-100"><%= vs.shieldCharges != null ? vs.shieldCharges : 0 %></span>
      </button>
      <button type="button" data-vault-item="focus" data-vault-action="use_focus_sip" data-can-use="<%= vs.canUseFocus ? 1 : 0 %>" data-name="Focus Charge" data-desc="Use to activate +1 focus charge for today." class="group relative flex aspect-square cursor-pointer items-center justify-center rounded-lg border border-zinc-700 bg-zinc-950/70 p-2 overflow-visible">
        <img src="/images/ui/item-focus.svg" alt="Focus Charge" class="h-5 w-5" />
        <span class="absolute bottom-1 right-1 rounded bg-zinc-700/95 px-1.5 py-0.5 font-mono text-[9px] leading-none text-zinc-100"><%= vs.focusVaultCharges != null ? vs.focusVaultCharges : 0 %></span>
      </button>
      <button type="button" data-vault-item="reroll" data-vault-action="use_daily_reroll" data-can-use="<%= vs.canUseReroll ? 1 : 0 %>" data-name="Daily Reroll Token" data-desc="Use to reroll one current daily quest offer (once per day)." class="group relative flex aspect-square cursor-pointer items-center justify-center rounded-lg border border-zinc-700 bg-zinc-950/70 p-2 overflow-visible">
        <img src="/images/ui/item-reroll.svg" alt="<%= curName %>" class="h-5 w-5" />
        <span class="absolute bottom-1 right-1 rounded bg-zinc-700/95 px-1.5 py-0.5 font-mono text-[9px] leading-none text-zinc-100"><%= vs.rerollCharges != null ? vs.rerollCharges : 0 %></span>
      </button>
      <button type="button" data-vault-item="astra" data-name="<%= curName %>" data-desc="Soft currency used to buy utility items in the shop." class="group relative flex aspect-square cursor-pointer items-center justify-center rounded-lg border border-zinc-700 bg-zinc-950/70 p-2 overflow-visible">
        <img src="/images/ui/item-reroll.svg" alt="<%= curName %>" class="h-5 w-5" />
        <span class="absolute bottom-1 right-1 rounded bg-amber-700/95 px-1.5 py-0.5 font-mono text-[9px] leading-none text-amber-50"><%= vs.astraBalance != null ? vs.astraBalance : 0 %></span>
      </button>
    </div>
    <div id="vault-item-info" class="mt-3 rounded-xl border border-zinc-700 bg-zinc-950/55 p-3">
      <p id="vault-item-name" class="font-display text-[10px] font-bold uppercase tracking-[0.12em] text-zinc-300">Item info</p>
      <p id="vault-item-desc" class="mt-1 font-ui text-[12px] text-zinc-400">Hover an item (or tap on mobile) to see details.</p>
      <form action="/inventory/vault" method="post" class="mt-3" data-auth-form>
        <input id="vault-use-action" type="hidden" name="action" value="" />
        <button id="vault-use-btn" type="submit" class="w-full rounded-lg border border-emerald-700/60 bg-emerald-900/35 px-3 py-2 font-display text-[10px] font-bold uppercase tracking-wider text-emerald-100 transition hover:bg-emerald-800/45">Use</button>
      </form>
    </div>
  </div>

  <div class="rounded-2xl border border-amber-600/35 bg-gradient-to-br from-amber-950/40 via-zinc-900 to-zinc-900 p-4 shadow-lg md:rounded-3xl md:p-5">
    <div class="mb-3 flex items-end justify-between gap-2">
      <h2 class="font-display text-[10px] font-bold uppercase tracking-[0.2em] text-amber-200/90">Shop</h2>
      <p class="font-ui text-xs text-zinc-400">Balance: <span class="font-semibold text-amber-100"><%= vs.astraBalance != null ? vs.astraBalance : 0 %></span> <%= curName %></p>
    </div>
    <% if (vs.migrationNeeded) { %>
    <p class="font-ui text-sm text-rose-200/90">Run <code class="rounded bg-zinc-950 px-1 py-0.5 text-xs">npm run db:migrate-astra-shop</code> then <code class="rounded bg-zinc-950 px-1 py-0.5 text-xs">npm run db:migrate-vault-manual</code> to enable manual-use Vault flow.</p>
    <% } else { %>
    <div id="shop-grid" class="grid grid-cols-4 gap-2">
      <button type="button" data-shop-action="daily_reroll" data-shop-qty="single" data-shop-name="Daily Reroll Token" data-shop-desc="Buy 1 token. Use it later from your Vault." data-shop-price="<%= p.reroll %>" data-shop-max="<%= vs.canDailyReroll ? 1 : 0 %>" class="relative flex aspect-square cursor-pointer items-center justify-center rounded-lg border border-zinc-700 bg-zinc-950/70 p-2 overflow-visible">
        <img src="/images/ui/item-reroll.svg" alt="Daily Quest Reroll" class="h-5 w-5" />
        <span class="absolute bottom-1 right-1 rounded bg-zinc-700/95 px-1.5 py-0.5 font-mono text-[9px] leading-none text-zinc-100"><%= vs.canDailyReroll ? 1 : 0 %></span>
      </button>
      <button type="button" data-shop-action="streak_shield" data-shop-qty="multi" data-shop-name="Streak Shield" data-shop-desc="Adds streak protection charge. You can buy multiple at once." data-shop-price="<%= p.shield %>" data-shop-max="<%= vs.maxShieldQty != null ? vs.maxShieldQty : 1 %>" class="relative flex aspect-square cursor-pointer items-center justify-center rounded-lg border border-zinc-700 bg-zinc-950/70 p-2 overflow-visible">
        <img src="/images/ui/item-shield.svg" alt="Streak Shield" class="h-5 w-5" />
        <span class="absolute bottom-1 right-1 rounded bg-zinc-700/95 px-1.5 py-0.5 font-mono text-[9px] leading-none text-zinc-100"><%= vs.maxShieldQty != null ? vs.maxShieldQty : 0 %></span>
      </button>
      <button type="button" data-shop-action="focus_sip" data-shop-qty="single" data-shop-name="Focus Charge" data-shop-desc="Buy 1 focus token. Use from Vault to activate it." data-shop-price="<%= p.focusSip %>" data-shop-max="<%= vs.canFocusSip ? 1 : 0 %>" class="relative flex aspect-square cursor-pointer items-center justify-center rounded-lg border border-zinc-700 bg-zinc-950/70 p-2 overflow-visible">
        <img src="/images/ui/item-focus.svg" alt="Focus Sip" class="h-5 w-5" />
        <span class="absolute bottom-1 right-1 rounded bg-zinc-700/95 px-1.5 py-0.5 font-mono text-[9px] leading-none text-zinc-100"><%= vs.canFocusSip ? 1 : 0 %></span>
      </button>
    </div>
    <form id="shop-buy-form" action="/inventory/vault" method="post" class="mt-3 rounded-xl border border-zinc-700 bg-zinc-950/55 p-3" data-auth-form>
      <input id="shop-buy-action" type="hidden" name="action" value="daily_reroll" />
      <p id="shop-item-name" class="font-display text-[10px] font-bold uppercase tracking-[0.12em] text-zinc-200">Daily Quest Reroll</p>
      <p id="shop-item-desc" class="mt-1 font-ui text-[12px] text-zinc-400">Swap one incomplete core daily quest. Once per server day.</p>
      <div class="mt-2 flex items-center gap-2">
        <label for="shop-buy-qty" class="font-ui text-[11px] text-zinc-500">Qty</label>
        <input id="shop-buy-qty" name="qty" type="number" min="1" max="1" value="1" class="w-16 rounded-lg border border-zinc-600 bg-zinc-900 px-2 py-1.5 font-mono text-xs text-zinc-100" />
        <p class="ml-auto font-mono text-[11px] text-amber-100">Cost: <span id="shop-item-cost"><%= p.reroll %></span> <%= curName %></p>
      </div>
      <button id="shop-buy-btn" type="submit" class="mt-3 w-full rounded-lg border border-violet-600/50 bg-violet-900/35 px-3 py-2 font-display text-[10px] font-bold uppercase tracking-wider text-violet-100 transition hover:bg-violet-800/45">Buy</button>
    </form>
    <% } %>
  </div>
</section>

<section class="mb-4 rounded-2xl border border-zinc-700 bg-gradient-to-br from-zinc-900 to-zinc-800/90 p-4 shadow-lg md:rounded-3xl md:p-5">
  <h2 class="mb-3 font-display text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">Equipment slots</h2>
  <div class="grid grid-cols-4 gap-2">
    <% for (let i = 0; i < 4; i++) { %>
      <div class="flex aspect-square items-center justify-center rounded-xl border border-dashed border-zinc-600 bg-zinc-950/50 font-ui text-[10px] text-zinc-500">—</div>
    <% } %>
  </div>
</section>

<section class="mb-4 rounded-2xl border border-zinc-700 bg-gradient-to-br from-zinc-900 to-zinc-800/90 p-4 shadow-lg md:rounded-3xl md:p-5">
  <h2 class="mb-3 font-display text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">Pets & spirits</h2>
  <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
    <% for (let i = 0; i < 4; i++) { %>
      <div class="flex aspect-[3/4] rotate-45 items-center justify-center overflow-hidden rounded-xl border border-zinc-600 bg-gradient-to-b from-zinc-800/90 to-zinc-900 shadow-inner">
        <span class="-rotate-45 font-display text-[10px] font-bold uppercase tracking-wider text-zinc-500">?</span>
      </div>
    <% } %>
  </div>
</section>

<section class="rounded-2xl border border-zinc-700 bg-gradient-to-br from-zinc-900 to-zinc-800/90 p-4 shadow-lg md:rounded-3xl md:p-5">
  <h2 class="mb-2 font-display text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">Party (coming soon)</h2>
  <p class="font-ui text-xs text-zinc-500">Recruit allies and share buffs — social layer after MVP.</p>
</section>

<script src="/js/vault-ui.js" defer></script>
