<article class="leaderboard-page w-full min-w-0 px-4 pb-6 pt-4 sm:px-5 sm:pt-5 md:px-6 md:pt-6">
  <div class="mb-5">
    <h1 class="font-display text-2xl font-bold uppercase tracking-wide text-zinc-50 sm:text-3xl md:text-4xl">Leaderboard</h1>
    <p class="mt-1 font-ui text-[13px] leading-relaxed text-zinc-400 sm:text-sm">
      Ranked by <strong class="font-semibold text-zinc-200">active class level</strong>, then <strong class="font-semibold text-zinc-200">total EXP</strong> on that class.
    </p>
  </div>

  <% if (typeof lbEmpty !== 'undefined' && lbEmpty) { %>
  <p class="w-full rounded-2xl border border-dashed border-zinc-600 bg-zinc-900 px-4 py-10 text-center font-ui text-sm text-zinc-400">No adventurers yet — be the first to level up.</p>
  <% } else { %>
  <ul class="m-0 flex w-full min-w-0 list-none flex-col gap-3 p-0">
    <% rows.forEach(function (row) { %>
      <li class="flex w-full min-w-0 items-center gap-3 rounded-2xl border p-3 shadow-md sm:gap-4 sm:p-4 md:rounded-3xl <%= row.highlight ? 'border-amber-500/50 bg-amber-950/30 shadow-lg ring-1 ring-amber-500/20' : 'border-zinc-700/80 bg-zinc-900 shadow-[0_4px_24px_-8px_rgba(0,0,0,0.45)]' %>">
        <div class="flex h-12 w-12 shrink-0 flex-col items-center justify-center">
          <% if (row.medal === 'gold') { %>
            <span class="text-3xl leading-none" aria-label="Rank 1">🥇</span>
          <% } else if (row.medal === 'silver') { %>
            <span class="text-3xl leading-none" aria-label="Rank 2">🥈</span>
          <% } else if (row.medal === 'bronze') { %>
            <span class="text-3xl leading-none" aria-label="Rank 3">🥉</span>
          <% } else { %>
            <span class="font-display text-lg font-bold tabular-nums text-zinc-500"><%= row.rank %></span>
          <% } %>
        </div>
        <div class="min-w-0 flex-1">
          <p class="truncate font-display text-sm font-bold uppercase tracking-wide text-zinc-100"><%= row.name %><% if (row.highlight) { %> <span class="font-ui text-[10px] font-semibold normal-case tracking-normal text-amber-300">(you)</span><% } %></p>
          <p class="mt-0.5 truncate font-ui text-[11px] text-zinc-400"><%= row.jobName %></p>
          <p class="mt-1 font-ui text-[10px] text-zinc-500">
            Login streak · <span class="font-mono font-semibold tabular-nums text-zinc-400"><%= row.streak %></span> days
          </p>
        </div>
        <div class="shrink-0 text-right">
          <p class="font-mono text-lg font-bold tabular-nums leading-none text-zinc-50">Lv.<%= row.level %></p>
          <p class="mt-1 font-mono text-[10px] font-semibold tabular-nums text-zinc-500"><%= row.totalExp.toLocaleString() %> EXP</p>
        </div>
      </li>
    <% }); %>
  </ul>
  <% } %>

  <a href="/quests" class="mt-8 block w-full text-center font-ui text-sm text-zinc-400 underline decoration-zinc-600 underline-offset-2 transition hover:text-zinc-200">← Back to quests</a>
</article>
