<%
  const ts = typeof trainStatus !== 'undefined' && trainStatus ? trainStatus : {};
  const trainToday = Number(ts.todayCount) || 0;
  const trainMax = Number(ts.dailyMax) || 3;
  const focusCharges = Number(ts.focusCharges) || 0;
  const tf = typeof trainFlash === 'string' ? trainFlash : '';
%>
<article class="training-page w-full min-w-0 px-4 pb-8 pt-4 sm:px-5 sm:pt-5 md:px-6 md:pt-6">
  <div class="mb-5 flex items-start justify-between gap-3 sm:mb-6">
    <div class="min-w-0">
      <h1 class="font-display text-2xl font-bold uppercase tracking-wide text-zinc-50 sm:text-3xl md:text-4xl">Train</h1>
      <p class="mt-1 font-ui text-[13px] text-zinc-400 sm:text-sm">Mini sessions for small EXP and next-task focus boost.</p>
    </div>
    <span class="rounded-lg border border-emerald-500/25 bg-emerald-950/20 px-2.5 py-1.5 font-display text-[8px] font-bold uppercase tracking-[0.12em] text-emerald-100">+8 EXP / session</span>
  </div>

  <section class="mb-4 rounded-xl border border-zinc-700/70 bg-zinc-900/60 px-3 py-3">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <p class="font-ui text-[12px] text-zinc-300">Train today: <span class="font-mono text-zinc-100"><%= trainToday %>/<%= trainMax %></span></p>
      <p class="font-ui text-[12px] text-zinc-300">Focus buff: <span class="font-mono text-zinc-100"><%= focusCharges %></span> charge</p>
    </div>
    <p class="mt-1 font-ui text-[11px] text-zinc-500">Each train gives +8 EXP. Max 3/day. Next completed task gets +5% EXP once.</p>
    <% if (trainToday >= trainMax) { %>
      <p class="mt-1 font-ui text-[11px] text-amber-300/90">Daily cap reached. Log session resets on next server day.</p>
    <% } %>
    <% if (tf) { %>
      <p class="mt-2 rounded-lg border border-violet-500/30 bg-violet-950/25 px-2.5 py-2 font-ui text-[11px] text-violet-100">
        <% if (tf === 'ok') { %>Training completed. EXP added and focus buff refreshed.
        <% } else if (tf === 'created') { %>Routine added.
        <% } else if (tf === 'updated') { %>Routine updated.
        <% } else if (tf === 'deleted') { %>Routine removed.
        <% } else if (tf === 'pick_routine') { %>Pick a routine first.
        <% } else if (tf === 'bad_routine') { %>Routine not found.
        <% } else if (tf === 'train_daily_cap') { %>Daily train cap reached (3/3). Come back tomorrow.
        <% } else if (tf === 'train_migration_needed') { %>Training migration needed: run `npm run db:migrate-train-reward`.
        <% } else { %>Training action: <%= tf %><% } %>
      </p>
    <% } %>
  </section>

  <section class="rounded-2xl border border-zinc-700/80 bg-gradient-to-br from-zinc-900 to-zinc-800 p-4 shadow-lg shadow-black/30 md:rounded-3xl md:p-5">
    <h2 class="mb-1 font-display text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">Your list</h2>
    <p class="mb-4 font-ui text-[11px] text-zinc-500">Pick one routine, do it in real life, then tap <span class="text-zinc-300">Log session</span>.</p>
    <form method="post" action="/training/routine/create" class="mb-3 grid grid-cols-1 gap-2 rounded-xl border border-zinc-700/80 bg-zinc-950/40 p-3 sm:grid-cols-3">
      <input name="title" required minlength="3" maxlength="80" placeholder="New routine title" class="min-h-[38px] rounded-lg border border-zinc-600 bg-zinc-900 px-3 py-2 font-ui text-sm text-zinc-100 outline-none focus:border-violet-500/60" />
      <input name="blurb" maxlength="180" placeholder="Short note (optional)" class="min-h-[38px] rounded-lg border border-zinc-600 bg-zinc-900 px-3 py-2 font-ui text-sm text-zinc-100 outline-none focus:border-violet-500/60 sm:col-span-2" />
      <button type="submit" class="inline-flex min-h-[38px] items-center justify-center rounded-lg border border-violet-500/35 bg-violet-950/25 px-3 font-display text-[8px] font-bold uppercase tracking-[0.12em] text-violet-100 transition hover:border-violet-400/50 sm:w-fit">Add routine</button>
    </form>
    <ul class="space-y-2">
      <% personalQuests.forEach(function (q) { %>
        <li class="rounded-xl border border-zinc-600/80 bg-zinc-950/50 px-3 py-3 shadow-sm">
          <div class="grid grid-cols-1 gap-2 sm:grid-cols-[1fr_auto] sm:items-start">
            <form method="post" action="/training/routine/update" class="min-w-0 grid grid-cols-1 gap-2">
              <input type="hidden" name="routineId" value="<%= q.id %>" />
              <input name="title" value="<%= q.title %>" required minlength="3" maxlength="80" class="min-h-[34px] rounded-lg border border-zinc-600 bg-zinc-900 px-2.5 py-1.5 font-ui text-[13px] text-zinc-100 outline-none focus:border-violet-500/60" />
              <input name="blurb" value="<%= q.blurb || '' %>" maxlength="180" class="min-h-[34px] rounded-lg border border-zinc-600 bg-zinc-900 px-2.5 py-1.5 font-ui text-[12px] text-zinc-300 outline-none focus:border-violet-500/60" />
              <button type="submit" class="inline-flex min-h-[30px] w-fit items-center justify-center rounded-lg border border-zinc-600 bg-zinc-800 px-2.5 font-display text-[8px] font-bold uppercase tracking-[0.12em] text-zinc-100 transition hover:border-zinc-500">Save</button>
            </form>
            <div class="flex flex-row items-center gap-2 sm:flex-col sm:items-stretch">
              <form method="post" action="/training/complete">
                <input type="hidden" name="routineId" value="<%= q.id %>" />
                <button
                  type="submit"
                  class="inline-flex min-h-[36px] items-center justify-center rounded-lg border border-emerald-500/35 bg-emerald-950/25 px-3 font-display text-[8px] font-bold uppercase tracking-[0.12em] text-emerald-100 transition hover:border-emerald-400/50 disabled:cursor-not-allowed disabled:opacity-50"
                  <%= trainToday >= trainMax ? 'disabled' : '' %>
                ><%= trainToday >= trainMax ? 'Cap reached' : 'Log session' %></button>
              </form>
              <form method="post" action="/training/routine/delete">
                <input type="hidden" name="routineId" value="<%= q.id %>" />
                <button type="submit" class="inline-flex min-h-[36px] items-center justify-center rounded-lg border border-rose-500/30 bg-rose-950/20 px-3 font-display text-[8px] font-bold uppercase tracking-[0.12em] text-rose-100 transition hover:border-rose-400/45">Delete</button>
              </form>
            </div>
          </div>
        </li>
      <% }); %>
    </ul>
  </section>

  <p class="mt-4 text-center font-ui text-[11px] text-zinc-500">Editing personal quests will connect to your account in a later step.</p>
</article>

