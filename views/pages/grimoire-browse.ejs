<% const cats = typeof categories !== 'undefined' && Array.isArray(categories) ? categories : []; %>
<% const q = typeof searchQuery === 'string' ? searchQuery : ''; %>
<% const results = typeof searchResults !== 'undefined' && Array.isArray(searchResults) ? searchResults : []; %>
<% const recent = typeof recentReads !== 'undefined' && Array.isArray(recentReads) ? recentReads : []; %>
<% function fmtRead(d) {
     try {
       const x = new Date(d);
       if (Number.isNaN(x.getTime())) return '';
       return x.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
     } catch { return ''; }
   }
%>
<article class="grimoire-browse mx-auto w-full max-w-4xl px-1 pb-8 pt-1 sm:px-2" lang="en">
  <p class="grimoire-browse__back font-ui mb-4 text-[13px]">
    <a
      href="/daily"
      class="font-medium text-violet-300 underline decoration-violet-500/50 underline-offset-2 transition-colors hover:text-violet-200 hover:decoration-violet-400/80"
    >
      ← Back to daily quests
    </a>
  </p>
  <header class="grimoire-browse__head mb-6 border-b border-zinc-700 pb-5">
    <p class="font-mono text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-500">Grimoire</p>
    <h1 class="font-display mt-2 text-xl font-bold uppercase leading-tight tracking-[0.04em] text-zinc-50 sm:text-2xl">
      Library
    </h1>
    <p class="font-ui mt-3 text-[14px] leading-relaxed text-zinc-400 sm:text-[15px]">
      Search titles and blurbs, jump back into recent reads, or open a topic below. Your INT card still offers one rotating pick per day.
    </p>
  </header>

  <section class="mb-8 space-y-4">
    <form method="get" action="/daily/grimoire/browse" class="flex flex-col gap-2 sm:flex-row sm:items-stretch" role="search">
      <label class="sr-only" for="grimoire-search-q">Search articles</label>
      <input
        id="grimoire-search-q"
        name="q"
        type="search"
        autocomplete="off"
        placeholder="Search articles (min. 2 characters)…"
        value="<%= q %>"
        class="min-h-[48px] flex-1 rounded-xl border border-zinc-600 bg-zinc-950 px-4 py-2.5 font-ui text-[15px] text-zinc-100 placeholder:text-zinc-500 outline-none focus:border-violet-500/55"
      />
      <button
        type="submit"
        class="inline-flex min-h-[48px] items-center justify-center rounded-xl border border-violet-500/40 bg-violet-950/40 px-5 font-display text-[10px] font-bold uppercase tracking-[0.14em] text-violet-100 transition hover:border-violet-400/55 hover:bg-violet-900/45"
      >Search</button>
    </form>
    <% if (q.length >= 2) { %>
      <% if (!results.length) { %>
        <p class="rounded-xl border border-dashed border-zinc-600 bg-zinc-900/60 px-4 py-6 text-center font-ui text-sm text-zinc-400">
          No articles match <strong class="text-zinc-200"><%= q %></strong>. Try another keyword or browse by topic below.
        </p>
      <% } else { %>
        <div>
          <h2 class="font-display text-[10px] font-bold uppercase tracking-[0.14em] text-zinc-400">Results (<%= results.length %>)</h2>
          <ul class="mt-3 space-y-2">
            <% results.forEach(function (a) { %>
            <li>
              <a
                href="/daily/grimoire/article/<%= a.slug %>"
                class="group block rounded-xl border border-zinc-600 bg-zinc-900/80 px-3.5 py-3 shadow-md shadow-black/15 transition hover:border-violet-500/45 hover:bg-zinc-800/90 sm:px-4 sm:py-3.5"
              >
                <span class="font-display block text-[11px] font-bold uppercase tracking-[0.06em] text-zinc-100 group-hover:text-white sm:text-xs">
                  <%= a.title %>
                </span>
                <span class="mt-1 block font-ui text-[11px] leading-snug text-zinc-400 sm:text-[12px]"><%= a.deck %></span>
                <span class="mt-1.5 inline-block font-mono text-[9px] font-bold uppercase tracking-[0.12em] text-violet-400/90"><%= a.categoryTitle %></span>
              </a>
            </li>
            <% }); %>
          </ul>
        </div>
      <% } %>
    <% } %>
  </section>

  <% if (recent.length) { %>
  <section class="mb-10" aria-labelledby="grimoire-recent-h">
    <h2 id="grimoire-recent-h" class="font-display text-[10px] font-bold uppercase tracking-[0.14em] text-zinc-400">Continue reading</h2>
    <ul class="mt-3 flex flex-wrap gap-2">
      <% recent.forEach(function (r) { %>
      <li>
        <a
          href="/daily/grimoire/article/<%= r.slug %>"
          class="inline-flex max-w-full flex-col rounded-xl border border-zinc-600 bg-gradient-to-br from-zinc-900/95 to-zinc-950/90 px-3 py-2 shadow-sm transition hover:border-amber-500/35 hover:from-zinc-800/90"
        >
          <span class="truncate font-display text-[10px] font-bold uppercase tracking-[0.06em] text-zinc-100"><%= r.title %></span>
          <span class="mt-0.5 font-mono text-[9px] text-zinc-500"><%= r.categoryTitle %><% if (r.lastReadAt) { %> · <%= fmtRead(r.lastReadAt) %><% } %></span>
        </a>
      </li>
      <% }); %>
    </ul>
  </section>
  <% } %>

  <h2 class="mb-3 font-display text-[10px] font-bold uppercase tracking-[0.14em] text-zinc-400">Browse by topic</h2>
  <ul class="grimoire-browse__grid m-0 grid list-none grid-cols-1 gap-3 p-0 sm:grid-cols-2">
    <% cats.forEach(function (c) { %>
    <li class="m-0 list-none">
      <a
        href="/daily/grimoire/category/<%= c.id %>"
        class="grimoire-browse__card group relative block h-full overflow-hidden rounded-xl border border-zinc-600 bg-zinc-900/80 p-4 shadow-md shadow-black/20 transition hover:border-violet-500/40 hover:bg-zinc-800/90 hover:shadow-lg"
      >
        <span class="pointer-events-none absolute -right-6 -top-6 h-24 w-24 rounded-full bg-violet-500/10 blur-2xl transition group-hover:bg-amber-400/10" aria-hidden="true"></span>
        <span class="relative flex flex-wrap items-baseline justify-between gap-2">
          <span class="font-display text-[11px] font-bold uppercase tracking-[0.08em] text-zinc-100 group-hover:text-white sm:text-xs">
            <%= c.title %>
          </span>
          <span class="font-mono text-[9px] font-bold uppercase tracking-[0.14em] text-zinc-500">
            <%= c.articleCount %> articles
          </span>
        </span>
        <span class="relative mt-2 block font-ui text-[12px] leading-relaxed text-zinc-400 sm:text-[13px]">
          <%= c.deck %>
        </span>
        <span class="relative mt-3 inline-flex items-center gap-1 font-display text-[9px] font-bold uppercase tracking-[0.16em] text-violet-300/95">
          Open topic
          <span aria-hidden="true" class="transition group-hover:translate-x-0.5">→</span>
        </span>
      </a>
    </li>
    <% }); %>
  </ul>
</article>
