<% const u = typeof gameUser !== 'undefined' ? gameUser : {}; %>
<% const lvl = u.level ?? 1; %>
<% const name = u.displayName ?? 'Adventurer'; %>
<% const expPct = Math.min(100, Math.max(0, u.expPct ?? 0)); %>
<% const expMaxLvl = u.expMaxLevel === true; %>
<% const expIn = Math.max(0, Number(u.expIntoLevel) || 0); %>
<% const expNeed = Math.max(0, Number(u.expToNextLevel) || 0); %>
<% const expCountTxt = expMaxLvl ? 'Max level' : expNeed > 0 ? expIn + '/' + expNeed + ' EXP' : expPct + '%'; %>
<% const job = u.job ?? 'Novice'; %>

<header class="sticky top-0 z-20 border-b border-ro-gold/15 bg-ro-deep/85 px-3 py-3 backdrop-blur-md sm:px-4">
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="font-display text-[10px] font-bold uppercase tracking-[0.35em] text-ro-mist/80">Lvl <%= lvl %></p>
      <p class="font-display text-lg font-bold leading-tight text-ro-cream"><%= name %></p>
      <p class="text-[11px] text-ro-mist/70"><%= job %></p>
    </div>
    <div class="flex items-center gap-2 rounded-full border border-ro-gold/25 bg-ro-panel/60 px-2.5 py-1.5 pr-3">
      <span class="flex h-7 w-7 items-center justify-center rounded-full bg-gradient-to-br from-ro-gold/30 to-ro-wine/40 text-sm" aria-hidden="true">✦</span>
      <span class="text-[10px] font-semibold uppercase tracking-wider text-ro-goldbright"><%= u.streak ?? 0 %> streak</span>
    </div>
  </div>
  <div class="mt-3">
    <div class="mb-1 flex justify-between gap-2 text-[10px] uppercase tracking-wider text-ro-mist/70">
      <span>EXP</span>
      <span class="text-right font-mono normal-case tabular-nums tracking-normal text-ro-mist/90"><%= expCountTxt %></span>
    </div>
    <div class="h-2 overflow-hidden rounded-full border border-ro-gold/20 bg-ro-ink/80">
      <div
        class="h-full rounded-full bg-gradient-to-r from-ro-wine/80 via-ro-gold to-ro-goldbright transition-all duration-500"
        style="width: <%= expPct %>%"
      ></div>
    </div>
  </div>
</header>
