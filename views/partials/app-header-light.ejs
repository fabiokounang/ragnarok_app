<% const u = typeof gameUser !== 'undefined' ? gameUser : {}; %>
<% const name = u.displayName ?? 'Adventurer'; %>
<% const username = String(u.username || '').trim(); %>
<% const lvl = u.level ?? 1; %>
<% const expPct = Math.min(100, Math.max(0, u.expPct ?? 0)); %>
<% const expMaxLvl = u.expMaxLevel === true; %>
<% const expIn = Math.max(0, Number(u.expIntoLevel) || 0); %>
<% const expNeed = Math.max(0, Number(u.expToNextLevel) || 0); %>
<% const expCountTxt = expMaxLvl ? 'Max level' : expNeed > 0 ? expIn + '/' + expNeed + ' EXP' : expPct + '%'; %>
<% const job = u.job ?? 'Novice'; %>
<% const astraBalance = Math.max(0, Number(u.astraBalance) || 0); %>
<% const jobEmblemLetter = String(job || 'N').trim().charAt(0).toUpperCase(); %>
<% const st = u.stats || {}; %>
<% const unspent = u.statPointsUnspent ?? 0; %>
<% const isProfile = typeof navActive === 'string' && navActive === 'profile'; %>
<%
const statOrder = ['str', 'agi', 'vit', 'int', 'dex', 'luk'];
const statLabels = { str: 'STR', agi: 'AGI', vit: 'VIT', int: 'INT', dex: 'DEX', luk: 'LUK' };
const statList = statOrder.map(function (k) {
  return { key: k, label: statLabels[k], v: Number(st[k] != null ? st[k] : 1) };
});
statList.sort(function (a, b) {
  if (b.v !== a.v) return b.v - a.v;
  return statOrder.indexOf(a.key) - statOrder.indexOf(b.key);
});
const topStats = statList.slice(0, 3);
const musicOnHeader = u.musicEnabled === true;
const hasMusicTrack = typeof ambientMusicSrc === 'string' && ambientMusicSrc.trim().length > 0;
const currencyLabel = typeof softCurrencyName === 'string' && softCurrencyName.trim() ? softCurrencyName.trim() : 'Astra';
%>

<header
  class="app-header-light z-20 w-full min-w-0 <%= isProfile
    ? 'mb-1 border-b border-zinc-800/90 bg-zinc-950/95 shadow-sm shadow-black/20'
    : 'sticky top-0 border-b border-zinc-800/90 bg-zinc-950/95 shadow-[0_8px_28px_-12px_rgba(0,0,0,0.45)] backdrop-blur-md' %>"
>
  <div class="w-full min-w-0 px-4 sm:px-5 md:px-6 <%= isProfile ? 'pb-3 pt-3 sm:pb-3.5 sm:pt-3.5' : 'pb-3 pt-3 sm:pt-4' %>">
    <% if (isProfile) { %>
    <h2 id="account-shortcuts-label" class="sr-only">Character and account</h2>
    <div class="flex items-start justify-between gap-2">
      <div class="flex min-w-0 flex-1 items-start gap-2.5">
        <div class="rb-job-emblem rb-job-emblem--sm mt-0.5 shrink-0" aria-hidden="true">
          <span class="rb-job-emblem__ring">
            <span class="rb-job-emblem__glyph"><%= jobEmblemLetter %></span>
          </span>
        </div>
        <div class="min-w-0 flex-1">
          <p class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
            <span class="max-w-full truncate font-display text-lg font-bold leading-tight tracking-tight text-zinc-50 sm:text-xl" title="<%= name %>"><%= name %></span>
            <% if (username) { %>
            <span class="font-mono text-[11px] leading-snug text-sky-300/90">@<%= username %></span>
            <% } %>
            <span class="font-ui text-[12px] leading-snug text-zinc-400 sm:text-[13px]">
              <span class="font-medium text-zinc-300"><%= job %></span><span class="mx-1 text-zinc-600" aria-hidden="true">·</span>Level <span id="app-header-level-num"><%= lvl %></span>
            </span>
          </p>
        </div>
      </div>
      <div class="flex shrink-0 items-center gap-1.5">
        <div
          class="rb-streak-pill flex shrink-0 flex-row items-center gap-1 rounded-lg border border-amber-500/40 bg-zinc-900 px-2 py-1 shadow-sm shadow-black/30"
          title="<%= currencyLabel %> balance"
        >
          <span class="font-display text-[7px] font-bold uppercase tracking-wider text-amber-300"><%= currencyLabel %></span>
          <span id="app-header-astra" class="font-mono text-[10px] font-semibold tabular-nums text-amber-100"><%= astraBalance %></span>
          <span class="sr-only"><%= currencyLabel %> balance</span>
        </div>
        <div
          class="rb-streak-pill flex shrink-0 flex-row items-center gap-1 rounded-lg border border-orange-500/40 bg-zinc-900 px-2 py-1 shadow-sm shadow-black/30"
          title="Login streak (days)"
        >
          <svg class="h-3.5 w-3.5 shrink-0 text-orange-400 drop-shadow-sm" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c0 3.5-2 6.5-4 8.5-.8.8-1.2 1.8-1.2 3 0 2.8 2.2 5 5 5s5-2.2 5-5c0-1.2-.4-2.2-1.2-3-2-2-4-5-4-8.5zm0 19c-2.2 0-4-1.6-4-3.8 0-.7.2-1.4.5-2 1.2 1.5 3 2.5 5.1 2.8.6-.8.9-1.8.9-2.8 0-1.2-.4-2.3-1.1-3.2 1.7.4 3.1 1.6 3.8 3.1.5 1 .8 2.1.8 3.1 0 2.2-1.8 3.8-4 3.8z"/></svg>
          <span class="font-mono text-[10px] font-bold tabular-nums text-orange-200"><%= u.streak ?? 0 %></span>
          <span class="font-display text-[7px] font-bold uppercase tracking-wider text-orange-300/90 whitespace-nowrap">days</span>
          <span class="sr-only">day login streak</span>
        </div>
        <div
          id="sound-heading"
          class="flex items-center gap-px rounded-lg border border-zinc-700/80 bg-zinc-900 p-px shadow-sm shadow-black/30"
          role="group"
          aria-label="In-app music"
        >
          <form action="/profile/music" method="post" class="m-0 inline" data-auth-form>
            <input type="hidden" name="enabled" value="1" />
            <button
              type="submit"
              title="Music on"
              aria-label="Turn in-app music on"
              class="flex h-7 w-7 items-center justify-center rounded-md border border-transparent font-display text-[8px] font-bold uppercase tracking-wider transition <%= musicOnHeader ? 'bg-violet-500/90 text-white' : 'text-zinc-400 hover:bg-zinc-800' %>"
            >
              <span class="auth-btn-label flex items-center justify-center" aria-hidden="true">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
              </span>
              <span class="auth-btn-spinner hidden h-3 w-3 animate-spin rounded-full border-2 border-violet-300/50 border-t-violet-800" aria-hidden="true"></span>
            </button>
          </form>
          <form action="/profile/music" method="post" class="m-0 inline" data-auth-form>
            <input type="hidden" name="enabled" value="0" />
            <button
              type="submit"
              title="Music off"
              aria-label="Turn in-app music off"
              class="flex h-7 w-7 items-center justify-center rounded-md border border-transparent font-display text-[8px] font-bold uppercase tracking-wider transition <%= !musicOnHeader ? 'bg-zinc-600 text-zinc-100' : 'text-zinc-500 hover:bg-zinc-800' %>"
            >
              <span class="auth-btn-label flex items-center justify-center" aria-hidden="true">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="m23 9-6 6"/><path d="m17 9 6 6"/></svg>
              </span>
              <span class="auth-btn-spinner hidden h-3 w-3 animate-spin rounded-full border-2 border-zinc-600 border-t-zinc-200" aria-hidden="true"></span>
            </button>
          </form>
        </div>
      </div>
    </div>

    <div id="app-header-exp-wrap" class="relative mt-2">
      <div class="mb-1 flex items-baseline justify-between gap-2">
        <span class="font-display text-[9px] font-semibold uppercase tracking-[0.12em] text-zinc-500">Experience</span>
        <span id="app-header-exp-text" class="text-right font-mono text-[10px] font-semibold tabular-nums leading-tight text-zinc-400 sm:text-[11px]"><%= expCountTxt %></span>
      </div>
      <div class="rb-exp-track h-2 overflow-hidden rounded-full border border-zinc-700/80 bg-zinc-800 shadow-inner">
        <div
          id="app-header-exp-fill"
          class="rb-exp-fill h-full rounded-full bg-gradient-to-r from-[#2c5f8d] via-[#d4a017] to-[#e8c547] transition-all duration-500"
          style="width: <%= expPct %>%"
        ></div>
      </div>
    </div>

    <div class="mt-2.5 flex items-center justify-between gap-2 border-t border-zinc-800/80 pt-2.5">
      <div class="min-w-0 flex-1">
        <p class="font-display text-[7px] font-bold uppercase tracking-[0.16em] text-zinc-500">Signed in as</p>
        <% if (typeof u.email !== 'undefined' && u.email) { %>
        <p class="truncate font-ui text-[11px] font-medium leading-snug text-zinc-200 sm:text-[12px]" title="<%= u.email %>"><%= u.email %></p>
        <% } else { %>
        <p class="font-ui text-[11px] leading-snug text-zinc-500">No email on file</p>
        <% } %>
      </div>
    </div>

    <% if (!hasMusicTrack) { %>
    <p class="mt-1.5 font-ui text-[10px] leading-snug text-amber-200/90">
      No audio file — add <span class="font-mono text-[9px]">public/audio/pokemon.mp3</span> or <span class="font-mono text-[9px]">AMBIENT_MUSIC_PATH</span>.
    </p>
    <% } %>

    <nav
      class="app-header-profile-pillnav mt-2 flex min-h-10 w-full max-w-full divide-x divide-zinc-700/80 overflow-x-auto rounded-full border border-zinc-700/80 bg-zinc-900 shadow-sm shadow-black/30 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      aria-label="Quick links and sign out"
    >
      <a
        href="/daily"
        class="flex min-w-[3rem] flex-1 items-center justify-center px-1 py-2 text-center font-display text-[7px] font-bold uppercase leading-tight tracking-wider text-zinc-200 transition hover:bg-zinc-800 sm:min-w-0 sm:px-1.5 sm:text-[8px] md:text-[9px]"
        >Tasks</a>
      <a
        href="/quests"
        class="flex min-w-[3rem] flex-1 items-center justify-center px-1 py-2 text-center font-display text-[7px] font-bold uppercase leading-tight tracking-wider text-zinc-200 transition hover:bg-zinc-800 sm:min-w-0 sm:px-1.5 sm:text-[8px] md:text-[9px]"
        >Quest</a>
      <a
        href="/leaderboard"
        class="flex min-w-[3rem] flex-1 items-center justify-center px-1 py-2 text-center font-display text-[7px] font-bold uppercase leading-tight tracking-wider text-zinc-200 transition hover:bg-zinc-800 sm:min-w-0 sm:px-1.5 sm:text-[8px] md:text-[9px]"
        >Leaderboard</a>
      <form action="/logout" method="post" class="m-0 flex min-w-[3rem] flex-1 sm:min-w-0">
        <button
          type="submit"
          class="w-full px-1 py-2 text-center font-display text-[7px] font-bold uppercase leading-tight tracking-wider text-rose-400 transition hover:bg-rose-950/50 sm:px-1.5 sm:text-[8px] md:text-[9px]"
          aria-label="Sign out"
        >
          Sign out
        </button>
      </form>
    </nav>
    <% } %>

    <% if (!isProfile) { %>
    <div class="rb-hero-status w-full min-w-0 rounded-2xl border border-zinc-700/80 bg-zinc-900 px-4 py-4 shadow-[0_6px_28px_-12px_rgba(0,0,0,0.45)] sm:rounded-3xl sm:px-5 sm:py-5 md:px-6 md:py-5">
      <div class="flex w-full min-w-0 items-start gap-3 sm:gap-4">
        <div class="rb-job-emblem shrink-0" aria-hidden="true" title="<%= job %>">
          <span class="rb-job-emblem__ring">
            <span class="rb-job-emblem__glyph"><%= jobEmblemLetter %></span>
          </span>
        </div>
        <div class="min-w-0 flex-1">
          <p class="font-display text-xl font-bold leading-tight tracking-tight text-zinc-50 sm:text-2xl md:text-[1.75rem]">
            <span class="block truncate" title="<%= name %>"><%= name %></span>
          </p>
          <% if (username) { %>
          <p class="mt-0.5 font-mono text-[11px] leading-snug text-sky-300/90 sm:text-[12px]">@<%= username %></p>
          <% } %>
          <p class="mt-1 font-ui text-[13px] leading-snug text-zinc-400 sm:text-[14px]">
            <span class="font-medium text-zinc-200"><%= job %></span>
            <span class="mx-1.5 text-zinc-600" aria-hidden="true">·</span>
            <span>Level <span id="app-header-level-num"><%= lvl %></span></span>
          </p>
        </div>
        <div class="flex shrink-0 flex-row items-center gap-2">
          <div
            class="rb-streak-pill flex shrink-0 flex-row items-center gap-1.5 rounded-xl border border-amber-500/35 bg-zinc-800/80 px-2.5 py-1.5 shadow-sm shadow-black/30"
            title="<%= currencyLabel %> balance"
          >
            <span class="font-display text-[7px] font-bold uppercase tracking-wider text-amber-300/90"><%= currencyLabel %></span>
            <span id="app-header-astra" class="font-mono text-[10px] font-semibold tabular-nums text-amber-100"><%= astraBalance %></span>
            <span class="sr-only"><%= currencyLabel %> balance</span>
          </div>
          <div
            class="rb-streak-pill flex shrink-0 flex-row items-center gap-1.5 rounded-xl border border-orange-500/35 bg-zinc-800/80 px-2.5 py-1.5 shadow-sm shadow-black/30"
            title="Login streak — keep the hearth lit"
          >
            <svg class="h-4 w-4 shrink-0 text-orange-400 drop-shadow-sm" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c0 3.5-2 6.5-4 8.5-.8.8-1.2 1.8-1.2 3 0 2.8 2.2 5 5 5s5-2.2 5-5c0-1.2-.4-2.2-1.2-3-2-2-4-5-4-8.5zm0 19c-2.2 0-4-1.6-4-3.8 0-.7.2-1.4.5-2 1.2 1.5 3 2.5 5.1 2.8.6-.8.9-1.8.9-2.8 0-1.2-.4-2.3-1.1-3.2 1.7.4 3.1 1.6 3.8 3.1.5 1 .8 2.1.8 3.1 0 2.2-1.8 3.8-4 3.8z"/></svg>
            <span class="font-mono text-[10px] font-bold tabular-nums text-orange-200"><%= u.streak ?? 0 %></span>
            <span class="font-display text-[7px] font-bold uppercase tracking-wider text-orange-300/90 whitespace-nowrap">days</span>
            <span class="sr-only">day login streak</span>
          </div>
        </div>
      </div>

      <div id="app-header-exp-wrap" class="relative mt-3.5 w-full min-w-0 sm:mt-4">
        <div class="mb-1.5 flex items-baseline justify-between gap-2">
          <span class="font-display text-[9px] font-semibold uppercase tracking-[0.14em] text-zinc-500">Experience</span>
          <span id="app-header-exp-text" class="text-right font-mono text-[10px] font-semibold tabular-nums leading-tight text-zinc-400 sm:text-[11px]"><%= expCountTxt %></span>
        </div>
        <div class="rb-exp-track h-2.5 w-full overflow-hidden rounded-full border border-zinc-700/80 bg-zinc-800 shadow-inner">
          <div
            id="app-header-exp-fill"
            class="rb-exp-fill h-full rounded-full bg-gradient-to-r from-[#2c5f8d] via-[#d4a017] to-[#e8c547] transition-all duration-500"
            style="width: <%= expPct %>%"
          ></div>
        </div>
      </div>

      <div class="mt-4 w-full min-w-0 border-t border-zinc-700/70 pt-3.5 sm:mt-5 sm:pt-4">
        <div class="flex w-full min-w-0 flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2">
              <span class="font-display text-[8px] font-bold uppercase tracking-[0.12em] text-zinc-500">Status</span>
              <span
                id="app-header-unspent"
                class="inline-flex w-fit rounded-lg border border-indigo-500/40 bg-indigo-950/50 px-2 py-1 font-mono text-[8px] font-bold uppercase tracking-wider text-indigo-200 <%= unspent > 0 ? '' : 'hidden' %>"
                title="Unspent stat points on this job"
                >+<%= unspent %> pts</span>
            </div>
            <div id="app-header-top-stats" class="mt-1 flex flex-wrap items-center gap-x-2 font-mono text-[11px] font-semibold tabular-nums text-zinc-200 sm:text-xs">
              <% topStats.forEach(function (row, i) { %>
              <% if (i > 0) { %><span class="text-zinc-600" aria-hidden="true">·</span><% } %>
              <span><%= row.label %> <%= row.v %></span>
              <% }); %>
            </div>
          </div>
          <div class="flex w-full min-w-0 shrink-0 flex-col gap-2 sm:w-auto sm:max-w-[14rem]">
            <div class="grid w-full grid-cols-2 gap-2 sm:min-w-[12rem]">
              <a
                href="/quests"
                class="flex min-h-[40px] items-center justify-center rounded-xl border border-zinc-600/80 bg-zinc-800 px-2 py-2 text-center font-display text-[9px] font-bold uppercase tracking-wider text-zinc-100 shadow-sm transition hover:border-zinc-500 hover:bg-zinc-700"
                >Quest</a>
              <a
                href="/profile"
                class="flex min-h-[40px] items-center justify-center rounded-xl border border-zinc-600/80 bg-zinc-800 px-2 py-2 text-center font-display text-[9px] font-bold uppercase tracking-wider text-zinc-100 shadow-sm transition hover:border-zinc-500 hover:bg-zinc-700"
                aria-label="Profile: jobs, stats, and settings"
                >Profile</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <% } %>
  </div>
</header>
