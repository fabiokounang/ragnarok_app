NODE_ENV=development
PORT=3000

# MySQL — copy to .env, then: npm run db:setup   (applies schema + seeds on Windows/Mac/Linux)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=reborn

# Required for login sessions (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string

# Optional in-app BGM (see public/audio/README.txt). Put MP3 under public/audio/. Empty = no file loaded.
# Default: /audio/pokemon.mp3
# AMBIENT_MUSIC_PATH=/audio/pokemon.mp3
# AMBIENT_MUSIC_VOLUME=0.22
